@page "/chat"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer

@using AskEiva.Domain.Repositories
@using AskEiva.Domain.Services
@using AskEiva.Domain.ValueObjects
@using AskEiva.Domain.Entities

@inject IKnowledgeRetrievalRepository RetrievalRepository
@inject IMistralChatService ChatService
@inject IJSRuntime JSRuntime

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-0" Style="height: calc(100vh - 130px); display: flex; flex-direction: column;">
    
    <MudPaper Elevation="0" Class="pa-4 mb-3 d-flex align-center justify-space-between flex-wrap gap-4" Style="border: 1px solid #E2E8F0; background: #FFFFFF; border-radius: 6px;">
        <div class="d-flex align-center flex-wrap gap-4">
            <div class="d-flex align-center gap-2 mr-2">
                <MudText Typo="Typo.subtitle2" Class="font-weight-bold" Style="color: #0A2540;">Cluster Node:</MudText>
                <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.CloudDone">Weaviate Online</MudChip>
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.Memory">Context Memory Active (@(_sessionHistory.Count) turns)</MudChip>
            </div>

            <div class="d-flex align-center gap-3 style-filter-group" style="border-left: 1px solid #CBD5E1; padding-left: 16px;">
                <MudSwitch @bind-Value="_includeTickets" Color="Color.Success" Size="Size.Small" T="bool">
                    <MudText Typo="Typo.caption" Class="@(_includeTickets ? "font-weight-bold color-active" : "color-inactive")">Tickets</MudText>
                </MudSwitch>
                
                <MudSwitch @bind-Value="_includeReleaseNotes" Color="Color.Info" Size="Size.Small" T="bool">
                    <MudText Typo="Typo.caption" Class="@(_includeReleaseNotes ? "font-weight-bold color-active" : "color-inactive")">ReleaseNotes</MudText>
                </MudSwitch>
                
                <MudSwitch @bind-Value="_includeDocumentation" Color="Color.Primary" Size="Size.Small" T="bool">
                    <MudText Typo="Typo.caption" Class="@(_includeDocumentation ? "font-weight-bold color-active" : "color-inactive")">Documentation</MudText>
                </MudSwitch>
            </div>
        </div>
        
        <MudButton Variant="Variant.Outlined" 
                   Color="Color.Error" 
                   Size="Size.Small" 
                   StartIcon="@Icons.Material.Filled.DeleteSweep" 
                   OnClick="ClearConversationSession"
                   Disabled="@(!_messageStream.Any(m => m.IsUser) || _isProcessing)">
            Delete Conversation
        </MudButton>
    </MudPaper>

    <MudPaper Elevation="0" Class="flex-grow-1 pa-4 overflow-y-auto mb-4 custom-chat-pane" Style="border: 1px solid #E2E8F0; background: #F8FAFC; min-height: 200px; border-radius: 8px;">
        <div class="d-flex flex-column gap-4">
            @foreach (var msg in _messageStream)
            {
                <div class="d-flex @(msg.IsUser ? "justify-end" : "justify-start")">
                    <div class="pa-4 shadow-sm" style="max-width: 85%; width: auto; min-width: 250px; background-color: @(msg.IsUser ? "#0A2540" : "#FFFFFF"); color: @(msg.IsUser ? "#FFFFFF" : "#0A2540"); border-radius: 8px; border: @(msg.IsUser ? "none" : "1px solid #E2E8F0");">
                        
                        <div class="d-flex align-center gap-2 mb-2">
                            <MudIcon Icon="@(msg.IsUser ? Icons.Material.Filled.Person : Icons.Material.Filled.SmartButton)" Size="Size.Small" Style="@($"color: {(msg.IsUser ? "#94A3B8" : "#0A2540")};")" />
                            <MudText Typo="Typo.caption" Class="font-weight-bold" Style="@($"color: {(msg.IsUser ? "#94A3B8" : "#64748B")};")">
                                @(msg.IsUser ? "User" : "AskEIVA Copilot Engine")
                            </MudText>
                        </div>

                        <div class="custom-markdown-render">
                            @((MarkupString)FormatMessageBody(msg.Text))
                        </div>
                        
                        @if (!msg.IsUser && (msg.SemanticMatches.Any() || msg.GraphChains.Any()))
                        {
                            <div class="mt-4 pt-3" style="border-top: 1px solid #F1F5F9;">
                                <MudExpansionPanels Elevation="0" Style="background: transparent;">
                                    <MudExpansionPanel Text="Citations" 
                                                       Icon="@Icons.Material.Filled.FactCheck"
                                                       Style="background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 6px;">
                                        
<MudTabs Elevation="0" Rounded="true" Color="Color.Primary" Outlined="true">
    
    @* Tab 1: KnowledgeNode (Tickets) *@
    <MudTabPanel Text="Tickets" Disabled="@(!HasSourceType(msg, "KnowledgeNode"))">
        <MudTable Items="@GetMatchesBySource(msg, "KnowledgeNode")" Dense="true" Hover="true" Elevation="0" Class="mt-2">
            <HeaderContent>
                <MudTh>Ticket Title / Identifier</MudTh>
                <MudTh>Proximity Score</MudTh>
                <MudTh>Content Preview Summary</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="font-weight: 500; font-size: 13px;"><a href="@context.SourceUrl" target="_blank" style="color: #0284C7; text-decoration: none;">@context.Title</a></MudTd>
                <MudTd Style="font-family: monospace;">@context.ConfidenceScore.ToString("F4")</MudTd>
                <MudTd Style="max-width: 450px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 12px; color: #64748B;">
                    <MudTooltip Text="@context.Content" Placement="Placement.Top">@context.Content</MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudTabPanel>

    @* Tab 2: SoftwareReleaseNode (Release Notes) *@
    <MudTabPanel Text="Release Notes" Disabled="@(!HasSourceType(msg, "SoftwareReleaseNode"))">
        <MudTable Items="@GetMatchesBySource(msg, "SoftwareReleaseNode")" Dense="true" Hover="true" Elevation="0" Class="mt-2">
            <HeaderContent>
                <MudTh>Release Version / Header</MudTh>
                <MudTh>Proximity Score</MudTh>
                <MudTh>Content Preview Summary</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="font-weight: 500; font-size: 13px;"><a href="@context.SourceUrl" target="_blank" style="color: #0369A1; text-decoration: none;">@context.Title</a></MudTd>
                <MudTd Style="font-family: monospace;">@context.ConfidenceScore.ToString("F4")</MudTd>
                <MudTd Style="max-width: 450px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 12px; color: #64748B;">
                    <MudTooltip Text="@context.Content" Placement="Placement.Top">@context.Content</MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudTabPanel>

    @* Tab 3: DocumentLibrary (Documentation Manuals) *@
    <MudTabPanel Text="Documentation" Disabled="@(!HasSourceType(msg, "DocumentLibrary"))">
        <MudTable Items="@GetMatchesBySource(msg, "DocumentLibrary")" Dense="true" Hover="true" Elevation="0" Class="mt-2">
            <HeaderContent>
                <MudTh>Manual Section / Origin</MudTh>
                <MudTh>Proximity Score</MudTh>
                <MudTh>Content Preview Summary</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="font-weight: 500; font-size: 13px;"><a href="@context.SourceUrl" target="_blank" style="color: #6B21A8; text-decoration: none;">@context.Title</a></MudTd>
                <MudTd Style="font-family: monospace;">@context.ConfidenceScore.ToString("F4")</MudTd>
                <MudTd Style="max-width: 450px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 12px; color: #64748B;">
                    <MudTooltip Text="@context.Content" Placement="Placement.Top">@context.Content</MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudTabPanel>

    @* Tab 4: GraphRAG Paths *@
    <MudTabPanel Text="GraphRAG" Disabled="@(!msg.GraphChains.Any())">
        <MudTable Items="msg.GraphChains" Dense="true" Hover="true" Elevation="0" Class="mt-2">
            <HeaderContent>
                <MudTh>Evidence Ref</MudTh>
                <MudTh>Product Anchor</MudTh>
                <MudTh>Knowledge Graph Pathway</MudTh>
                <MudTh>Confidence</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><MudText Typo="Typo.caption" Style="font-weight: bold; color: #0284C7;">@context.TicketId</MudText></MudTd>
                <MudTd><MudChip T="string" Variant="Variant.Text" Size="Size.Small" Color="Color.Primary">@context.MainProductContext</MudChip></MudTd>
                <MudTd Style="font-family: monospace; font-size: 11px; color: #0F172A; background: #F1F5F9; border-radius: 4px; padding: 6px;">@context.SharedPathChain</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">@context.ConfidenceScore%</MudChip></MudTd>
            </RowTemplate>
        </MudTable>
    </MudTabPanel>

</MudTabs>
                                    </MudExpansionPanel>
                                </MudExpansionPanels>
                            </div>
                        }
                    </div>
                </div>
            }
            @if (_isProcessing && string.IsNullOrWhiteSpace(_streamingChunkBuffer))
            {
                <div class="d-flex justify-start">
                    <div class="pa-4 rounded bg-white shadow-sm" style="border: 1px solid #E2E8F0;">
                        <div class="d-flex align-center gap-3">
                            <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
                            <MudText Typo="Typo.caption" Style="color: #64748B;">Retrieving and distilling subsea knowledge engines...</MudText>
                        </div>
                    </div>
                </div>
            }
        </div>
    </MudPaper>

    <MudPaper Elevation="0" Class="pa-3" Style="border: 1px solid #E2E8F0; background: #FFFFFF; border-radius: 8px;">
        <div class="d-flex align-center gap-3">
            <MudTextField @bind-Value="_currentPrompt" 
                          Placeholder="Ask a follow up question regarding NaviSuite models, ROTV tracking systems, or ticket behaviors..." 
                          Variant="Variant.Text" 
                          Underline="false"
                          OnKeyDown="HandleKeyDown"
                          Lines="1"
                          MaxLines="4"
                          Immediate="true"
                          Class="flex-grow-1" />
            <MudIconButton Icon="@Icons.Material.Filled.Send" 
                           Color="Color.Primary" 
                           OnClick="SubmitPrompt" 
                           Disabled="@(string.IsNullOrWhiteSpace(_currentPrompt) || _isProcessing || !IsAnySourceChecked())" />
        </div>
    </MudPaper>
</MudContainer>

<style>
    .color-active { color: #0A2540 !important; }
    .color-inactive { color: #94A3B8 !important; }
    .type-badge { display: inline-block; padding: 2px 6px; border-radius: 4px; font-size: 10px; text-transform: uppercase; font-weight: bold; }
    .type-badge.ticket { background: #DCFCE7; color: #15803D; }
    .type-badge.releasenote { background: #E0F2FE; color: #0369A1; }
    .type-badge.documentation { background: #F3E8FF; color: #6B21A8; }
</style>

@code {
    private string _currentPrompt = string.Empty;
    private bool _isProcessing = false;
    private string _streamingChunkBuffer = string.Empty;

    private bool _includeTickets = true;
    private bool _includeReleaseNotes = true;
    private bool _includeDocumentation = true;
    
    private List<ChatTurn> _sessionHistory = new();
    
    private List<UIConversationMessage> _messageStream = new()
    {
        new UIConversationMessage 
        { 
            Text = "Welcome to AskEIVA. I have mapped the software release records, dynamic manuals, and historical interaction repositories. How can I help you support vessel operations today?", 
            IsUser = false 
        }
    };

    private bool IsAnySourceChecked() => _includeTickets || _includeReleaseNotes || _includeDocumentation;

    // Checks tab disable states safely
    private bool HasSourceType(UIConversationMessage message, string targetType)
    {
        if (message?.SemanticMatches == null) return false;
        return message.SemanticMatches.Any(m => string.Equals(m.SourceType, targetType, StringComparison.OrdinalIgnoreCase));
    }

    // 💡 THE ULTIMATE FIX: Filters the items safely inside pure C# space to bypass the Razor property quote generator bug
    private IEnumerable<RetrievalMatch> GetMatchesBySource(UIConversationMessage message, string targetType)
    {
        if (message?.SemanticMatches == null) return Enumerable.Empty<RetrievalMatch>();
        
        return message.SemanticMatches.Where(m => string.Equals(m.SourceType, targetType, StringComparison.OrdinalIgnoreCase));
    }

    private async Task SubmitPrompt()
    {
        if (string.IsNullOrWhiteSpace(_currentPrompt) || _isProcessing || !IsAnySourceChecked()) return;

        var userText = _currentPrompt;
        _currentPrompt = string.Empty;
        _isProcessing = true;
        _streamingChunkBuffer = string.Empty;

        _messageStream.Add(new UIConversationMessage { Text = userText, IsUser = true });
        await ScrollToBottom();

        var responseMessage = new UIConversationMessage { Text = "", IsUser = false };
        _messageStream.Add(responseMessage);

        try
        {
            // 1. Fetch a wider list of underlying contexts from Weaviate to ensure all categories are represented
            var completeSemanticMatches = await RetrievalRepository.SearchSemanticChunksAsync(userText, limit: 12);
            
            //  Targets your true Weaviate collection schemas: KnowledgeNode, SoftwareReleaseNode, and DocumentLibrary
            var filteredMatches = completeSemanticMatches.Where(m => 
                (m.SourceType.Equals("KnowledgeNode", StringComparison.OrdinalIgnoreCase) && _includeTickets) ||
                (m.SourceType.Equals("SoftwareReleaseNode", StringComparison.OrdinalIgnoreCase) && _includeReleaseNotes) ||
                (m.SourceType.Equals("DocumentLibrary", StringComparison.OrdinalIgnoreCase) && _includeDocumentation)
            ).ToList(); // Remove the restrictive .Take(3) so the context window gets complete data packages

            responseMessage.SemanticMatches = filteredMatches;

            // 2. Call your SearchGraphTriplesAsync contract to pull true GraphContextChains
            var activeGraphChains = await RetrievalRepository.SearchGraphTriplesAsync(userText, limit: 5);
            responseMessage.GraphChains = activeGraphChains.ToList();

            await foreach (var chunk in ChatService.GenerateStreamingChatResponseAsync(userText, responseMessage.SemanticMatches, responseMessage.GraphChains, _sessionHistory))
            {
                _streamingChunkBuffer += chunk;
                responseMessage.Text = _streamingChunkBuffer;
                StateHasChanged();
                await ScrollToBottom();
            }

            _sessionHistory.Add(new ChatTurn(userText, IsUser: true));
            _sessionHistory.Add(new ChatTurn(_streamingChunkBuffer, IsUser: false));

            _ = Task.Run(async () => 
            {
                try
                {
                    bool isSuccess = !string.IsNullOrWhiteSpace(_streamingChunkBuffer) && !_streamingChunkBuffer.StartsWith("Stream Memory Allocation Error");
                    await RetrievalRepository.LogInteractionAsync(userText, _streamingChunkBuffer, isSuccess);
                }
                catch (Exception telemetryEx)
                {
                    System.Diagnostics.Debug.WriteLine($"Background telemetry commit drop: {telemetryEx.Message}");
                }
            });
        }
        catch (Exception ex)
        {
            responseMessage.Text = $"Stream Memory Allocation Error: {ex.Message}";
        }
        finally
        {
            _isProcessing = false;
            await ScrollToBottom();
        }
    }

    private void ClearConversationSession()
    {
        _sessionHistory.Clear();
        _messageStream.Clear();
        _messageStream.Add(new UIConversationMessage 
        { 
            Text = "Conversation context deleted. Session restarted. Ready for fresh queries.", 
            IsUser = false 
        });
        StateHasChanged();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SubmitPrompt();
        }
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(10);
        await JSRuntime.InvokeVoidAsync("eval", "document.querySelector('.custom-chat-pane')?.scrollTo(0, 100000)");
    }

    private string FormatMessageBody(string rawText)
    {
        if (string.IsNullOrWhiteSpace(rawText)) return "...";

        var sb = new System.Text.StringBuilder(rawText);
        sb.Replace("&", "&amp;").Replace("<", "&lt;").Replace(">", "&gt;");
        var text = sb.ToString();

        text = System.Text.RegularExpressions.Regex.Replace(text, @"\*\*(.*?)\*\*", "<strong>$1</strong>");
    
        text = System.Text.RegularExpressions.Regex.Replace(text, @"`(.*?)`", "<code style='background: #F1F5F9; padding: 2px 4px; border-radius: 4px; font-family: monospace; color: #DC2626;'>$1</code>");

        var tableRegex = new System.Text.RegularExpressions.Regex(@"((?:\|[^|\r\n]*)+\|(?:\r?\n?)+)+");
        text = tableRegex.Replace(text, match =>
        {
            var lines = match.Value.Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);
            if (lines.Length < 2) return match.Value;

            var htmlTable = new System.Text.StringBuilder("<div class='overflow-x-auto my-3'>");
            htmlTable.Append("<table class='markdown-styled-table' style='width:100%; border:1px solid #CBD5E1; border-collapse:collapse; background:#FFFFFF; font-size:0.85rem;'>");
            bool isHeader = true;

            foreach (var line in lines)
            {
                if (line.Contains("---|") || line.Contains("---:|") || !line.Contains("|")) continue;
                var columns = line.Split('|').Select(c => c.Trim()).Where((c, idx) => idx > 0 && idx < line.Split('|').Length - 1).ToList();

                htmlTable.Append("<tr style='border-bottom:1px solid #E2E8F0;'>");
                foreach (var col in columns)
                {
                    if (isHeader)
                        htmlTable.Append($"<th style='padding:10px; background:#F8FAFC; text-align:left; font-weight:bold; color:#0A2540; border-bottom:2px solid #CBD5E1;'>{col}</th>");
                    else
                        htmlTable.Append($"<td style='padding:10px; text-align:left; color:#334155;'>{col}</td>");
                }
                htmlTable.Append("</tr>");
                isHeader = false;
            }
            htmlTable.Append("</table></div>");
            return htmlTable.ToString();
        });

        text = System.Text.RegularExpressions.Regex.Replace(text, @"^\s*-\s+(.*?)$", "<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        text = text.Replace("\n", "<br />");
        return text;
    }

    public class UIConversationMessage
    {
        public string Text { get; set; } = string.Empty;
        public bool IsUser { get; set; }
        public List<RetrievalMatch> SemanticMatches { get; set; } = new();
        public List<GraphContextChain> GraphChains { get; set; } = new();
    }
}